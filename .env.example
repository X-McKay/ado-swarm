APP_ENV=local
LOG_LEVEL=INFO
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=ado-swarm
DATABASE_URL=postgresql://ado_swarm:ado_swarm@localhost:5432/ado_swarm
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ado_swarm_dev_password
SOURCE_PROVIDER=stub
KNOWLEDGE_BACKEND=memory
MODEL_PROVIDER=fake
MODEL_ID=fake-deterministic
MODEL_BASE_URL=
# OpenTelemetry GenAI tracing (off by default). When TRACING_ENABLED=true, the
# OTLP exporter uses OTEL_EXPORTER_OTLP_ENDPOINT; OTEL_EXPORTER=console for stdout.
TRACING_ENABLED=false
OTEL_EXPORTER=otlp
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Adjudication swarm (opt-in; decide via `ado-swarm eval-swarm`)
SECURITY_REVIEWER_USE_SWARM=false
ADO_ORG_URL=
ADO_PROJECT=
ADO_PAT=
GITHUB_TOKEN=
GITHUB_OWNER=
